{
    "name": "assegaiphp/orm",
    "description": "AssegaiORM is a standalone ORM for modern PHP applications, with optional AssegaiPHP integration.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Assegai\\Orm\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Andrew Masiye",
            "email": "amasiye313@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-intl": "*",
        "assegaiphp/util": "^0.9.0",
        "psr/log": "^3.0",
        "symfony/console": "^8.0",
        "predis/predis": "^2.3"
    },
    "suggest": {
        "assegaiphp/core": "Optional: enables framework-aware config and repository integration inside Assegai applications.",
        "assegaiphp/console": "Optional: enables Assegai CLI installers and ORM command discovery.",
        "ext-pdo_mysql": "Enable this if your app uses MySQL or MariaDB connections.",
        "ext-pdo_pgsql": "Enable this if your app uses PostgreSQL connections.",
        "ext-pdo_sqlsrv": "Enable this if your app uses Microsoft SQL Server connections.",
        "ext-pdo_sqlite": "Enable this if your app uses SQLite connections."
    },
    "require-dev": {
        "codeception/codeception": "^5.0",
        "codeception/module-phpbrowser": "*",
        "codeception/module-asserts": "*",
        "codeception/module-db": "^3.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "scripts": {
        "test": "vendor/bin/phpunit -c phpunit.xml",
        "test:unit": "vendor/bin/phpunit -c phpunit.xml",
        "test:mysql": "vendor/bin/phpunit -c phpunit.mysql.xml",
        "test:mssql": "vendor/bin/phpunit -c phpunit.mssql.xml",
        "test:pgsql": "vendor/bin/phpunit -c phpunit.pgsql.xml",
        "test:sqlite": "php -d register_argc_argv=On vendor/bin/codecept run SQLite",
        "test:legacy-unit": "php -d register_argc_argv=On vendor/bin/codecept run Unit"
    },
    "config": {
    },
    "extra": {
        "assegai": {
            "aliases": [
                "orm"
            ],
            "installer": "Assegai\\Orm\\Assegai\\Console\\OrmPackageInstaller",
            "commands": [
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Database\\DatabaseConfigure",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Database\\DatabaseLoad",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Database\\DatabaseSeed",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Database\\DatabaseSetup",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Migration\\MigrationCreate",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Migration\\MigrationList",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Migration\\MigrationUp",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Migration\\MigrationDown",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Migration\\MigrationRefresh",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Migration\\MigrationSetup",
                "Assegai\\Orm\\Assegai\\Console\\Commands\\Migration\\MigrationRedo"
            ]
        }
    }
}
